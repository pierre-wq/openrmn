# Anthropic — clé API pour le brief IA
ANTHROPIC_API_KEY=sk-ant-...

# Reverse proxy — path préfixe servi par nginx (ex: /retail-audience)
ROOT_PATH=/retail-audience

# Accès au lab — si défini, toute requête HTML passe par /login
OPENRMN_PASSWORD=change-me
OPENRMN_SESSION_SECRET=change-me-too

# Amazon Ads — LWA Security Profile (à renseigner manuellement)
AMZ_LWA_CLIENT_ID=
AMZ_LWA_CLIENT_SECRET=

# Amazon Ads — remplis automatiquement par le flow OAuth
# (GET /api/amazon/oauth/start)
AMZ_REFRESH_TOKEN=
AMZ_PROFILE_ID=

# Criteo Retail Media (optionnel — sinon mode mock)
CRITEO_API_KEY=
CRITEO_ACCOUNT_ID=
